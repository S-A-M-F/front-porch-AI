<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- PyInstaller sidecar entitlements.
	     These are applied to all bundled ML-engine executables (kokoro_tts, piper,
	     whisper_stt, sentiment_classifier, dt_grpc_client) and their *.so/.dylib
	     helpers. Required because the hardened runtime would otherwise block the
	     PyInstaller boot-loader from mapping the embedded Python bytecode archive
	     into executable memory and from loading unsigned extension modules (.so). -->

	<!-- Allow the PyInstaller bootstrap to load Python's .so extension modules
	     that are bundled inside _internal/ but not individually signed by us. -->
	<key>com.apple.security.cs.disable-library-validation</key>
	<true/>

	<!-- Allow the PyInstaller bootstrap to mmap the bundled .pyc archive as
	     executable memory (required for all PyInstaller onedir bundles on
	     macOS with hardened runtime). -->
	<key>com.apple.security.cs.allow-unsigned-executable-memory</key>
	<true/>

	<!-- Network client: dt_grpc_client needs to reach Draw Things gRPC server
	     (typically localhost:7859). The other sidecars don't need this but it
	     is harmless. The main .app entitlements already carry this; sidecars
	     are separate processes so they need it too. -->
	<key>com.apple.security.network.client</key>
	<true/>
</dict>
</plist>
